@bot.callback_query_handler(func=lambda call: True)
def handle_query(call):
    if call.data == "check":
        if is_subscribed(call.from_user.id):
            bot.edit_message_text("✅ تم التحقق! أرسل /start وابدأ الطلب.", call.message.chat.id, call.message.message_id)
        else:
            bot.answer_callback_query(call.id, "لسه ما اشتركتش يا بودة! ❌", show_alert=True)

    elif "order_" in call.data:
        service = "واتساب 🟢" if "wa" in call.data else "تليجرام 🔵"
        
        # إرسال إشعار للأدمن (بودة)
        admin_msg = (
            f"🚨 **طلب رقم جديد يا ملك!**\n"
            f"━━━━━━━━━━━━━━\n"
            f"👤 العميل: {call.from_user.first_name}\n"
            f"🆔 الأيدي: `{call.from_user.id}`\n"
            f"📱 الخدمة: {service}\n"
            f"━━━━━━━━━━━━━━\n"
            f"👇 اضغط على المعرف لمراسلته:"
            f"tg://user?id={call.from_user.id}"
        )
        bot.send_message(ADMIN_ID, admin_msg, parse_mode="Markdown")
        
        # رد على المستخدم
        bot.answer_callback_query(call.id, "✅ تم إرسال طلبك للأدمن بنجاح!", show_alert=True)
        bot.edit_message_text(f"{header()}✨ **تم استلام طلبك!**\n\nانتظر رسالة من الأدمن بالرقم الخاص بك خلال دقائق.\n{header()}", call.message.chat.id, call.message.message_id)

